# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Packaging/build artifacts
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Logs
logs/
*.log

# Runtime state (keep dir, ignore contents by default)
state/*
!state/.gitkeep
state/*.db
state/*.db-wal
state/*.db-shm

# Local helper scripts (do not commit)
scripts/

# Local config secrets/overrides
config/*.local.yaml
config/*.secret.yaml
config/config.d/99-local.yaml
.env
.env.*

# IDE/editor files
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Local planning notes
Documents/Next_task.txt
